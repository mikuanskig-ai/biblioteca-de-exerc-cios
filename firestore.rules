rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper para verificar se o ID é válido e seguro
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper para validação da estrutura do Exercício
    function isValidExercise(data) {
      return data.keys().hasAll(['id', 'nome', 'slug', 'categoria', 'grupoMuscular'])
        && data.id is string
        && data.id.size() <= 128
        && data.nome is string
        && data.nome.size() <= 256
        && data.slug is string
        && data.slug.size() <= 256
        && data.categoria is string
        && data.categoria.size() <= 128
        && data.grupoMuscular is string
        && data.grupoMuscular.size() <= 128;
    }

    // Coleção de Exercícios
    // Leitura pública (biblioteca é um catálogo público de treinos).
    // Escrita: valida ao menos o formato do dado contra injeção de lixo/malformado.
    // NOTA DE SEGURANÇA: sem Firebase Auth configurado, não há como o Firestore
    // distinguir "o servidor confiável" de "qualquer visitante" - fechar create/update/delete
    // para exigir um identity check real requer Firebase Auth (ou migrar o servidor para o
    // Admin SDK com uma service account, que bypassa estas regras). Isso exige uma ação manual
    // no Console do Firebase que não pode ser feita por aqui.
    match /exercises/{exerciseId} {
      allow read: if true;
      allow create, update: if isValidId(exerciseId) && isValidExercise(request.resource.data);
      allow delete: if true;
    }
  }
}
