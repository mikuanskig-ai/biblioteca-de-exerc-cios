rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper para verificar se o ID é válido e seguro
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper para validação da estrutura do Exercício
    function isValidExercise(data) {
      return data.keys().hasAll(['id', 'nome', 'slug', 'categoria', 'grupoMuscular'])
        && data.id is string
        && data.id.size() <= 128
        && data.nome is string
        && data.nome.size() <= 256
        && data.slug is string
        && data.slug.size() <= 256
        && data.categoria is string
        && data.categoria.size() <= 128
        && data.grupoMuscular is string
        && data.grupoMuscular.size() <= 128;
    }

    // Identidade dedicada usada apenas pelo servidor (Express/Vercel) para gravar no Firestore.
    // Nenhum outro usuário consegue se autenticar com este e-mail (a senha só existe como
    // variável de ambiente no servidor), então isto distingue "o backend confiável" de
    // qualquer visitante que tente escrever direto pelo SDK do Firebase.
    function isTrustedServer() {
      return request.auth != null
        && request.auth.token.email == 'firestore-server@bia-tisatto-exercicios.internal';
    }

    // Coleção de Exercícios
    // Leitura pública (biblioteca é um catálogo público de treinos).
    // Escrita: somente a conta de serviço do backend, com validação de schema como defesa extra.
    match /exercises/{exerciseId} {
      allow read: if true;
      allow create, update: if isTrustedServer() && isValidId(exerciseId) && isValidExercise(request.resource.data);
      allow delete: if isTrustedServer();
    }
  }
}
