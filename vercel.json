{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "includeFiles": "data/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api/|assets/|exercicios/).*)",
      "destination": "/index.html"
    }
  ]
}
